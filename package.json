{
  "name": "sencha",
  "private": true,
  "scripts": {
    "dev": "sst dev",
    "dev:site": "bunx browser-sync start --server website --port 3000 --files \"website/**/*\" --host 127.0.0.1 --no-open",
    "deploy": "sst deploy",
    "deploy:prod": "sst deploy --stage production",
    "remove": "sst remove",
    "remove:prod": "sst remove --stage production",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "browser-sync": "^3.0.4",
    "typescript": "^5"
  },
  "dependencies": {
    "sst": "^4.17.1"
  }
}
